# Per4Biz — template de variáveis de ambiente (V1 single-tenant)
# Copiar para .env (nunca commitar .env real)
# Ver 07-v1-scope/EXECUTION-NOTES.md §4 para o que é obrigatório em V1

# ============================================
# USER gating (V1 single-tenant)
# ============================================
# Email Google do único utilizador autorizado. FastAPI rejeita qualquer
# id_token cujo `email` não corresponda a este valor.
ALLOWED_USER_EMAIL=jpbertilhopt@gmail.com

# UUID fixo do JP (gerar uma vez com `uuidgen` ou Python):
# python -c "import uuid; print(uuid.uuid4())"
USER_ID=00000000-0000-0000-0000-000000000001

# ============================================
# Supabase (DB + Storage — SEM Auth/RLS em V1)
# Região EU: Paris (eu-west-3) ou Frankfurt (eu-central-1)
# ============================================
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_ANON_KEY não é usada em V1 (sem cliente Supabase Auth no browser)

# ============================================
# Google OAuth 2.0 (contas operacionais — Gmail)
# Scopes em V1: gmail.readonly + gmail.send + gmail.modify + openid email profile
# Calendar + Contacts entram só em V2 (incremental authorization)
# ============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://per4biz.vercel.app/auth/google/callback
# Dev: http://localhost:8000/auth/google/callback

# ============================================
# Groq (único provider LLM+STT em V1 — sem Anthropic)
# ============================================
GROQ_API_KEY=
GROQ_STT_MODEL=whisper-large-v3
GROQ_LLM_MODEL=llama-3.3-70b-versatile

# ============================================
# ElevenLabs (TTS feminina PT-PT streaming)
# Escolher voice_id no Sprint 2 (pt-PT female voice)
# ============================================
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ============================================
# Encryption (AES-256-GCM para refresh tokens Google)
# Gerar com: python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# ============================================
ENCRYPTION_KEY=
ENCRYPTION_KEY_VERSION=1

# ============================================
# Next.js frontend (Vercel)
# ============================================
NEXT_PUBLIC_APP_URL=https://per4biz.vercel.app
NEXT_PUBLIC_API_URL=https://per4biz-api.fly.dev
# Dev local:
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================
# Auth interno BFF ↔ FastAPI (bearer simples em V1)
# ============================================
INTERNAL_API_SHARED_SECRET=
# Gerar com: openssl rand -hex 32

# ============================================
# Rate limits (hard-coded em V1 — sem Redis)
# ============================================
RATE_LIMIT_VOICE_INTERACTIONS_PER_DAY=200
RATE_LIMIT_EMAILS_SEND_PER_DAY=100

# ============================================
# Feature flags V1
# ============================================
FEATURE_VOICE_AGENT_ENABLED=true
FEATURE_MULTI_ACCOUNT_ENABLED=false       # ligar em Sprint 4
FEATURE_PUSH_NOTIFICATIONS_ENABLED=false  # ligar em Sprint 5 (revisto)
FEATURE_CALENDAR_ENABLED=false            # V2 definitivo
FEATURE_CONTACTS_ENABLED=false            # V2 definitivo
FEATURE_TRANSCRIPT_RETENTION=false        # opt-in; user liga em Settings

# ============================================
# OPCIONAIS (V1.x / V2) — deixar em branco em V1
# ============================================
# ANTHROPIC_API_KEY=            # não usado em V1 (só Groq)
# UPSTASH_REDIS_REST_URL=       # não usado em V1 (sem rate limit externo)
# UPSTASH_REDIS_REST_TOKEN=
# SENTRY_DSN=                   # adicionar quando houver volume
# AXIOM_TOKEN=                  # observability completa em V1.x
# AXIOM_DATASET=per4biz-logs
